# Vesta environment variables — EXAMPLE ONLY.
# Copy to .env.local and fill in real values. NEVER commit real secrets.
# Phase 0 (dashboard shell) needs NONE of these. They are placeholders for
# later phases (Supabase, Microsoft Graph, AI) and are documented here early
# so the required surface is known.

# ---------- Supabase (Phase 1+) ----------
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the browser/frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Dev/E2E test user (development only) ----------
# A throwaway account used for manual testing + the Playwright auth fixture.
# Create it with: node scripts/create-dev-user.mjs  (needs the service role key).
# Remove the account before launch and re-enable Supabase email confirmation.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# ---------- Microsoft Graph / Outlook OAuth (Phase 3+) ----------
# Server-only.
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT_ID=
MS_GRAPH_REDIRECT_URI=

# ---------- Token encryption (Phase 3+) ----------
# Server-only. Used to encrypt Microsoft tokens at rest.
TOKEN_ENCRYPTION_KEY=

# ---------- AI provider (Phase 7+) ----------
# Server-only.
AI_API_KEY=
AI_MODEL=
