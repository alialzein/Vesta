# Vesta environment variables — EXAMPLE ONLY.
# Copy to .env.local and fill in real values. NEVER commit real secrets.
# Phase 0 (dashboard shell) needs NONE of these. They are placeholders for
# later phases (Supabase, Microsoft Graph, AI) and are documented here early
# so the required surface is known.

# ---------- Supabase (Phase 1+) ----------
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the browser/frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Dev/E2E test user (development only) ----------
# A throwaway account used for manual testing + the Playwright auth fixture.
# Create it with: node scripts/create-dev-user.mjs  (needs the service role key).
# Remove the account before launch and re-enable Supabase email confirmation.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# ---------- Microsoft Graph / Outlook OAuth (Phase 3) ----------
# Server-only. ONE Azure app registration for all users (not per-user).
# See docs/reference/architecture/outlook-connect-setup.md for how to create it.
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
# 'common' = multi-tenant + personal Microsoft accounts (recommended).
MS_GRAPH_TENANT=common
# Optional. The redirect URI auto-derives from the current domain
# (<origin>/api/outlook/callback); set this ONLY to override (e.g. behind a
# proxy). You still register the actual callback URL(s) on the Azure app.
# MS_GRAPH_REDIRECT_URI=

# ---------- Token encryption (Phase 3) ----------
# Server-only. Encrypts Microsoft tokens at rest (AES-256-GCM, key = sha256 of this).
# Use a long random value, e.g. `openssl rand -hex 32`.
TOKEN_ENCRYPTION_KEY=

# ---------- AI provider (Phase 7+) ----------
# Server-only. Provider + model are config-driven so they can be swapped later
# (e.g. from the admin panel). AI_PROVIDER selects the adapter (openai | anthropic).
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
AI_API_KEY=
# Optional cost guards (analysis is bounded by these):
# AI_MAX_PER_RUN=20      # items analyzed per sync run
# AI_MAX_PER_DAY=200     # items analyzed per user per day
# Optional pricing for cost estimates (USD per 1M tokens). Set these for OpenAI
# rates so ai_analyses.cost_estimate_usd is populated; otherwise tokens are still
# tracked and cost is left null.
# AI_PRICE_INPUT=
# AI_PRICE_OUTPUT=
